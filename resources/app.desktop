[Desktop Entry]
Name=LiquidMon
Comment=COSMIC panel applet for AIO liquid cooler temps and fan/pump duties via liquidctl
Type=Application
Icon=com.github.cosmix.LiquidMon
Exec=liquidmon %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
